---
import type { PublicProject } from "../lib/registry";
import type { Dict } from "../i18n/zh";

interface Props {
  p: PublicProject;
  dict: Dict;
  big?: boolean;
}
const { p, dict, big = false } = Astro.props;

function stageColor(stage: string): string {
  switch (stage) {
    case "All-in":
      return "border-void-accent/50 bg-void-accent/[0.06]";
    case "活跃":
      return "border-sky-400/30 bg-sky-400/[0.04]";
    case "野化":
      return "border-fuchsia-400/30 bg-fuchsia-400/[0.04]";
    case "Watch":
      return "border-blue-400/30 bg-blue-400/[0.04]";
    case "停滞":
      return "border-slate-500/25 bg-slate-500/[0.03]";
    case "已归档":
    case "Kill":
      return "border-slate-700/30 bg-slate-900/20 opacity-60";
    default:
      return "border-slate-700/30";
  }
}

function stageDot(stage: string): string {
  switch (stage) {
    case "All-in":
      return "bg-void-accent shadow-[0_0_10px_2px_rgba(34,211,238,0.5)]";
    case "活跃":
      return "bg-sky-400";
    case "野化":
      return "bg-fuchsia-400";
    case "Watch":
      return "bg-blue-400";
    case "停滞":
      return "bg-slate-500";
    default:
      return "bg-slate-600";
  }
}

// 产品图标占位 — 用项目名首字母 + 渐变背景
function projectInitial(name: string): string {
  return name.replace(/[^A-Za-z]/g, "").slice(0, 2).toUpperCase() || "⚡";
}

const colorCls = stageColor(p.stage);
const dotCls = stageDot(p.stage);
const stageText = dict.projects.stageLabels[p.stage] ?? p.stage;
const desc = p.description?.trim() || dict.projects.fallbackDescription;
const sizeCls = big
  ? "md:col-span-2 lg:col-span-2 md:row-span-2 p-6 md:p-8"
  : "p-5 md:p-6";
---

<article
  class:list={[
    "project-card relative rounded-2xl border backdrop-blur-md flex flex-col justify-between gap-3",
    colorCls,
    sizeCls,
  ]}
>
  <header class="flex items-start gap-4">
    {/* 产品图标占位 */}
    <div class:list={[
      "shrink-0 rounded-xl flex items-center justify-center font-mono font-bold text-void-bg/80 bg-gradient-to-br from-void-accent/80 to-void-accent2/80",
      big ? "w-14 h-14 text-xl" : "w-10 h-10 text-sm",
    ]}>
      {projectInitial(p.name)}
    </div>
    <div class="flex flex-col gap-1.5 min-w-0">
      <div class="flex items-center gap-2 font-mono text-[10px] uppercase tracking-[0.25em] text-void-mute">
        <span class={`inline-block w-1.5 h-1.5 rounded-full ${dotCls}`}></span>
        <span>{stageText}</span>
        {p.freq_total !== null && p.freq_total !== undefined && (
          <span class="text-void-accent/60">· {dict.projects.freqLabel} {p.freq_total}</span>
        )}
      </div>
      <h3
        class:list={[
          "font-mono text-void-fg leading-tight break-words",
          big ? "text-2xl md:text-3xl" : "text-base md:text-lg",
        ]}
      >
        {p.name}
      </h3>
    </div>
  </header>

  <p
    class:list={[
      "text-void-mute leading-relaxed flex-1",
      big ? "text-sm md:text-base max-w-xl" : "text-xs md:text-sm",
    ]}
  >
    {desc}
  </p>

  {p.tech_stack.length > 0 && (
    <div class="flex flex-wrap gap-1.5">
      {p.tech_stack.slice(0, 4).map((t) => (
        <span class="font-mono text-[9px] px-1.5 py-0.5 rounded bg-void-accent/10 text-void-accent/70 border border-void-accent/15">
          {t}
        </span>
      ))}
    </div>
  )}

  <footer class="flex items-end justify-between gap-3 pt-2 border-t border-cyan-900/30">
    <div class="font-mono text-[10px] text-void-mute/70 leading-relaxed truncate min-w-0 flex-1">
      {p.last_action ? (
        <>
          <span class="text-void-accent/50">{dict.projects.lastActionLabel} · {p.last_action.date}</span>
          <br />
          <span class="text-void-mute truncate block">{p.last_action.message}</span>
        </>
      ) : (
        <span class="text-void-mute/40">—</span>
      )}
    </div>
    {p.github_url && (
      <a
        href={p.github_url}
        target="_blank"
        rel="noopener noreferrer"
        class="shrink-0 font-mono text-[10px] uppercase tracking-widest text-void-mute hover:text-void-accent transition px-2 py-1 border border-cyan-800/40 rounded-md hover:border-void-accent/60 hover:bg-void-accent/5"
      >
        {dict.projects.repoLabel} ↗
      </a>
    )}
  </footer>
</article>

<style>
  .project-card {
    transition: transform 0.4s cubic-bezier(0.2, 0.8, 0.2, 1),
      border-color 0.4s, background-color 0.4s, box-shadow 0.4s;
  }
  .project-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 30px rgba(34, 211, 238, 0.08);
  }
</style>
