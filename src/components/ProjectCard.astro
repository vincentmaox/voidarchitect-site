---
import type { PublicProject } from "../lib/registry";
import type { Dict } from "../i18n/zh";
import { PRODUCT_DETAILS, productSlug } from "../lib/product-details";

interface Props {
  p: PublicProject;
  dict: Dict;
  big?: boolean;
  locale?: "zh" | "en";
}
const { p, dict, big = false, locale = "zh" } = Astro.props;

function stageBadge(stage: string): string {
  switch (stage) {
    case "All-in":
      return "bg-void-ink text-white border-void-ink";
    case "活跃":
      return "bg-void-accent/10 text-void-accent border-void-accent/20";
    case "野化":
      return "bg-void-hot/10 text-void-hot border-void-hot/20";
    case "Watch":
      return "bg-[#eef5ff] text-[#2563eb] border-[#bfdbfe]";
    case "停滞":
      return "bg-void-ash text-void-mute border-void-border/70";
    default:
      return "bg-void-ash text-void-mute border-void-border/60";
  }
}

function appGradient(stage: string): string {
  switch (stage) {
    case "All-in":
      return "from-void-ink via-[#143766] to-void-accent";
    case "活跃":
      return "from-[#eaf5ff] via-void-accent2 to-void-accent";
    case "野化":
      return "from-[#fff1e9] via-void-hot to-[#ffb199]";
    case "Watch":
      return "from-[#f5f8ff] via-[#9fc8ff] to-[#2563eb]";
    default:
      return "from-[#f8fafc] via-[#e5e9f0] to-[#9aa4b2]";
  }
}

const badgeCls = stageBadge(p.stage);
const gradientCls = appGradient(p.stage);
const stageText = dict.projects.stageLabels[p.stage] ?? p.stage;
const desc = p.description?.trim() || dict.projects.fallbackDescription;
const initials = p.name.replace(/[^A-Za-z0-9]/g, "").slice(0, 2).toUpperCase() || "VA";
const productLabel = p.product_label?.trim() || "Independent App";
const coverImage = p.cover_image?.trim();
const slug = productSlug(p);
const detail = slug ? PRODUCT_DETAILS[slug] : null;
const storyHook = detail?.copy[locale].storyHook;
const detailHref = slug ? `${locale === "en" ? "/en" : ""}/projects/${slug}` : null;
const coverTransition = slug ? `product-cover-${slug}` : undefined;
const titleTransition = slug ? `product-title-${slug}` : undefined;
const sizeCls = big ? "md:col-span-2 lg:col-span-2 md:row-span-2" : "";
---

<article
  class:list={[
    "project-card gradient-border relative flex flex-col overflow-hidden rounded-[2rem] md:rounded-[2.35rem]",
    sizeCls,
  ]}
>
  <a
    href={detailHref ?? p.github_url ?? "#"}
    aria-label={`Open ${p.name} product page`}
    class:list={[
      "relative mx-4 mt-4 block shrink-0 overflow-hidden rounded-[1.55rem] border border-white/70 bg-gradient-to-br shadow-[inset_0_1px_0_rgba(255,255,255,0.55),0_26px_70px_rgba(28,39,58,0.13)]",
      gradientCls,
      big ? "h-56 md:h-80" : "h-40",
    ]}
  >
    {coverImage ? (
      <>
        <img src={coverImage} alt={`${p.name} cover`} loading="lazy" decoding="async" transition:name={coverTransition} class="absolute inset-0 h-full w-full object-cover" />
        <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(5,7,10,0.04)_0%,rgba(5,7,10,0.12)_38%,rgba(5,7,10,0.48)_100%)]" />
      </>
    ) : (
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_25%_18%,rgba(255,255,255,0.72),transparent_28%),radial-gradient(circle_at_78%_70%,rgba(255,255,255,0.34),transparent_36%)]" />
    )}
    <div class="absolute inset-x-5 bottom-5 rounded-[1.25rem] border border-white/45 bg-white/26 p-3 shadow-[0_18px_50px_rgba(5,7,10,0.12)] backdrop-blur-2xl">
      <div class="flex items-center gap-3">
        <div class="grid rounded-[1.05rem] bg-white/84 font-mono font-semibold text-void-ink shadow-[0_12px_30px_rgba(5,7,10,0.12)]"
          class:list={big ? "h-16 w-16 place-items-center text-xl" : "h-12 w-12 place-items-center text-sm"}
        >
          {initials}
        </div>
        <div class="min-w-0 text-white drop-shadow-[0_1px_8px_rgba(5,7,10,0.28)]">
          <p class="truncate font-semibold tracking-[-0.03em]" class:list={big ? "text-2xl" : "text-base"}>{p.name}</p>
          <p class="font-mono text-[10px] uppercase tracking-[0.16em] opacity-80">{productLabel}</p>
        </div>
      </div>
    </div>
  </a>

  <div class="relative z-10 flex flex-1 flex-col gap-4 p-5 md:p-6" class:list={big ? "md:p-8" : ""}>
    <div class="flex flex-wrap items-center gap-2">
      <span class="inline-flex items-center rounded-full border border-void-border/70 bg-white/76 px-3 py-1 font-mono text-[10px] uppercase tracking-wider text-void-ink/72 shadow-[inset_0_1px_0_rgba(255,255,255,0.82)]">
        {productLabel}
      </span>
      <span class={`inline-flex items-center gap-1.5 rounded-full border px-3 py-1 font-mono text-[10px] uppercase tracking-wider ${badgeCls}`}>
        <span class="inline-block h-1.5 w-1.5 rounded-full bg-current" />
        {stageText}
      </span>
      {p.freq_total !== null && p.freq_total !== undefined && (
        <span class="rounded-full bg-void-ash px-3 py-1 font-mono text-[10px] text-void-ink/58">
          {dict.projects.freqLabel} {p.freq_total}
        </span>
      )}
    </div>

    <h3 transition:name={titleTransition} class:list={["leading-[1.02] tracking-[-0.055em] text-void-ink", big ? "text-3xl font-bold md:text-5xl" : "text-2xl font-bold"]}>
      {p.name}
    </h3>

    {storyHook && (
      <p class:list={["font-semibold leading-snug tracking-[-0.025em] text-void-ink", big ? "text-lg md:text-xl" : "text-base"]}>
        {storyHook}
      </p>
    )}

    <p class:list={["leading-relaxed text-void-ink/62", big ? "text-base md:text-lg" : "text-sm"]}>
      {desc}
    </p>

    {p.tech_stack.length > 0 && (
      <div class="flex flex-wrap gap-1.5">
        {p.tech_stack.slice(0, 5).map((t) => (
          <span class="rounded-full border border-void-border/60 bg-white/68 px-2.5 py-1 font-mono text-[9px] uppercase tracking-[0.08em] text-void-mute shadow-[inset_0_1px_0_rgba(255,255,255,0.75)]">
            {t}
          </span>
        ))}
      </div>
    )}

    <div class="mt-auto flex items-end justify-between gap-3 border-t border-void-border/60 pt-4">
      <div class="min-w-0 flex-1 truncate font-mono text-[10px] leading-relaxed text-void-mute/80">
        {p.last_action ? (
          <>
            <span class="text-void-accent">{dict.projects.lastActionLabel} · {p.last_action.date}</span>
            <br />
            <span class="block truncate text-void-mute">{p.last_action.message}</span>
          </>
        ) : (
          <span class="text-void-mute/40">—</span>
        )}
      </div>
      <div class="flex shrink-0 items-center gap-2">
        {detailHref && (
          <a
            href={detailHref}
            class="rounded-full bg-void-ink px-3 py-2 font-mono text-[10px] uppercase tracking-widest text-white transition hover:bg-void-accent"
          >
            Product →
          </a>
        )}
        {p.github_url && (
          <a
            href={p.github_url}
            target="_blank"
            rel="noopener noreferrer"
            class="rounded-full border border-void-border/70 bg-white/70 px-3 py-2 font-mono text-[10px] uppercase tracking-widest text-void-ink/62 transition hover:border-void-ink hover:bg-void-ink hover:text-white"
          >
            {dict.projects.repoLabel} ↗
          </a>
        )}
      </div>
    </div>
  </div>
</article>

<style>
  .project-card {
    background: rgba(255, 255, 255, 0.72);
    backdrop-filter: blur(34px) saturate(175%);
    border: 1px solid rgba(255, 255, 255, 0.78);
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.88), 0 28px 90px rgba(28, 39, 58, 0.12);
    transition: transform 0.55s cubic-bezier(0.2, 0.8, 0.2, 1), box-shadow 0.55s, border-color 0.55s;
  }
  .project-card:hover {
    transform: translateY(-8px) scale(1.01);
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.95), 0 42px 120px rgba(28, 39, 58, 0.18), 0 18px 60px rgba(0, 122, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.95);
  }
</style>
