---
import type { PublicProject } from "../lib/registry";
import type { Dict } from "../i18n/zh";

interface Props {
  p: PublicProject;
  dict: Dict;
  big?: boolean;
}
const { p, dict, big = false } = Astro.props;

function stageColor(stage: string): string {
  switch (stage) {
    case "All-in":
      return "border-void-accent/40";
    case "活跃":
      return "border-sky-400/30";
    case "野化":
      return "border-fuchsia-400/30";
    case "Watch":
      return "border-blue-400/30";
    case "停滞":
      return "border-slate-500/20";
    case "已归档":
    case "Kill":
      return "border-slate-700/20 opacity-50";
    default:
      return "border-void-border/30";
  }
}

function stageBadge(stage: string): string {
  switch (stage) {
    case "All-in":
      return "bg-void-accent/15 text-void-accent border-void-accent/30";
    case "活跃":
      return "bg-sky-400/10 text-sky-400 border-sky-400/20";
    case "野化":
      return "bg-fuchsia-400/10 text-fuchsia-400 border-fuchsia-400/20";
    case "Watch":
      return "bg-blue-400/10 text-blue-400 border-blue-400/20";
    case "停滞":
      return "bg-slate-500/10 text-slate-400 border-slate-500/20";
    default:
      return "bg-slate-700/10 text-slate-500 border-slate-700/20";
  }
}

const colorCls = stageColor(p.stage);
const badgeCls = stageBadge(p.stage);
const stageText = dict.projects.stageLabels[p.stage] ?? p.stage;
const desc = p.description?.trim() || dict.projects.fallbackDescription;
const sizeCls = big
  ? "md:col-span-2 lg:col-span-2 md:row-span-2"
  : "";
---

<article
  class:list={[
    "project-card relative rounded-2xl overflow-hidden flex flex-col",
    colorCls,
    sizeCls,
  ]}
>
  <!-- 渐变顶部色带（图片占位区） -->
  <div
    class:list={[
      "relative w-full overflow-hidden flex items-center justify-center shrink-0",
      big ? "h-48 md:h-64" : "h-32",
    ]}
  >
    <div class="absolute inset-0 bg-gradient-to-br from-void-accent/20 via-void-accent2/10 to-void-hot/10" />
    <div class="absolute inset-0 opacity-30"
      style="background-image: url('data:image/svg+xml,%3Csvg width=\'60\' height=\'60\' viewBox=\'0 0 60 60\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cg fill=\'none\' fill-rule=\'evenodd\'%3E%3Cg fill=\'%2300D4FF\' fill-opacity=\'0.05\'%3E%3Cpath d=\'M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z\'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"
    />
    <div class="relative z-10 font-mono font-bold text-void-accent/40"
      class:list={big ? "text-5xl md:text-6xl" : "text-3xl md:text-4xl"}
    >
      {p.name.replace(/[^A-Za-z]/g, "").slice(0, 2).toUpperCase() || "⚡"}
    </div>
  </div>

  <!-- 玻璃拟态内容区 -->
  <div class="relative z-10 flex-1 flex flex-col gap-3 p-5 md:p-6"
    class:list={big ? "md:p-8" : ""}
  >
    <div class="flex items-center gap-2">
      <span class={`inline-flex items-center gap-1.5 px-2 py-0.5 rounded-full font-mono text-[10px] uppercase tracking-wider border ${badgeCls}`}>
        <span class="inline-block w-1.5 h-1.5 rounded-full bg-current" />
        {stageText}
      </span>
      {p.freq_total !== null && p.freq_total !== undefined && (
        <span class="font-mono text-[10px] text-void-accent/50">
          {dict.projects.freqLabel} {p.freq_total}
        </span>
      )}
    </div>

    <h3
      class:list={[
        "font-mono text-void-fg leading-tight",
        big ? "text-2xl md:text-3xl" : "text-lg md:text-xl",
      ]}
    >
      {p.name}
    </h3>

    <p
      class:list={[
        "text-void-mute leading-relaxed",
        big ? "text-sm md:text-base" : "text-xs md:text-sm",
      ]}
    >
      {desc}
    </p>

    {p.tech_stack.length > 0 && (
      <div class="flex flex-wrap gap-1.5">
        {p.tech_stack.slice(0, 4).map((t) => (
          <span class="font-mono text-[9px] px-2 py-0.5 rounded-full bg-void-surface/50 text-void-mute border border-void-border/40"
          >
            {t}
          </span>
        ))}
      </div>
    )}

    <div class="flex items-end justify-between gap-3 pt-2 mt-auto border-t border-void-border/30"
    >
      <div class="font-mono text-[10px] text-void-mute/70 leading-relaxed truncate min-w-0 flex-1"
      >
        {p.last_action ? (
          <>
            <span class="text-void-accent/40">{dict.projects.lastActionLabel} · {p.last_action.date}</span>
            <br />
            <span class="text-void-mute truncate block">{p.last_action.message}</span>
          </>
        ) : (
          <span class="text-void-mute/30">—</span>
        )}
      </div>
      {p.github_url && (
        <a
          href={p.github_url}
          target="_blank"
          rel="noopener noreferrer"
          class="shrink-0 font-mono text-[10px] uppercase tracking-widest text-void-mute hover:text-void-accent transition px-2.5 py-1 border border-void-border/50 rounded-lg hover:border-void-accent/50 hover:bg-void-accent/5"
        >
          {dict.projects.repoLabel} ↗
        </a>
      )}
    </div>
  </div>
</article>

<style>
  .project-card {
    background: rgba(22, 27, 34, 0.5);
    backdrop-filter: blur(20px) saturate(140%);
    transition: transform 0.4s cubic-bezier(0.2, 0.8, 0.2, 1),
      box-shadow 0.4s, border-color 0.4s;
  }
  .project-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 40px rgba(0, 212, 255, 0.06),
                0 0 0 1px rgba(0, 212, 255, 0.15);
    border-color: rgba(0, 212, 255, 0.3);
  }
</style>
