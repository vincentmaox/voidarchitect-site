---
import Layout from "../layouts/Layout.astro";
import FluidHero from "./FluidHero.tsx";
import ProjectGrid from "./ProjectGrid.astro";
import type { Dict } from "../i18n/zh";

interface Props {
  dict: Dict;
  lang: "zh-CN" | "en";
}
const { dict, lang } = Astro.props;
---

<Layout title={dict.meta.title} description={dict.meta.description} lang={lang}>
  <main class="relative min-h-screen">
    <FluidHero client:only="react" />

    <section class="relative min-h-screen flex flex-col justify-between p-8 md:p-16">
      <header class="flex justify-between items-center text-sm font-mono uppercase tracking-widest text-void-mute">
        <span>{dict.nav.studio}</span>
        <span class="hidden md:inline">{dict.nav.person}</span>
        <div class="flex items-center gap-4">
          <a href={dict.langSwitch.otherHref} class="hover:text-void-fg transition" aria-label="switch language">
            {dict.langSwitch.other}
          </a>
          <a href={`mailto:${dict.nav.contact}`} class="hover:text-void-fg transition hidden sm:inline">
            {dict.nav.contact}
          </a>
        </div>
      </header>

      <div class="flex flex-col gap-6 max-w-5xl">
        <p class="font-mono text-xs uppercase tracking-[0.3em] text-void-mute">
          {dict.hero.eyebrow}
        </p>
        <h1 class="text-display text-[clamp(3rem,11vw,11rem)] text-void-fg">
          {dict.hero.title1}<br />{dict.hero.title2}
        </h1>
        <p class="max-w-2xl text-lg md:text-xl text-void-mute leading-relaxed">
          {dict.hero.body.map((line, i) => (
            <>{line}{i < dict.hero.body.length - 1 && <br />}</>
          ))}
        </p>
      </div>

      <footer class="flex justify-between items-end font-mono text-xs uppercase tracking-widest text-void-mute">
        <a href="#projects" class="hover:text-void-fg transition flex items-center gap-2">
          <span>{dict.hero.scroll}</span>
        </a>
        <span class="hidden md:block">{dict.hero.location}</span>
      </footer>
    </section>

    <ProjectGrid dict={dict} />

    <footer class="relative bg-void-bg border-t border-zinc-800/50 py-10 px-6 md:px-16">
      <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between gap-4 font-mono text-xs uppercase tracking-widest text-void-mute">
        <span>{dict.footer.rights}</span>
        <div class="flex gap-6">
          <a href={`mailto:${dict.nav.contact}`} class="hover:text-void-fg transition">
            {dict.nav.contact}
          </a>
          <span class="hidden md:inline">{dict.footer.poweredBy}</span>
        </div>
      </div>
    </footer>
  </main>
</Layout>
