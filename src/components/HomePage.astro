---
import Layout from "../layouts/Layout.astro";
import FluidHero from "./FluidHero.tsx";
import ProjectGrid from "./ProjectGrid.astro";
import type { Dict } from "../i18n/zh";

interface Props {
  dict: Dict;
  lang: "zh-CN" | "en";
}
const { dict, lang } = Astro.props;
---

<Layout title={dict.meta.title} description={dict.meta.description} lang={lang}>
  <main class="relative min-h-screen">
    {/* Hero: 流体做全屏背景 + 文字叠加 */}
    <section class="relative min-h-screen flex flex-col justify-between overflow-hidden">
      <FluidHero client:only="react" />

      {/* 半透明渐变叠层——让文字可读但保留流体感 */}
      <div class="absolute inset-0 bg-gradient-to-b from-void-bg/30 via-transparent to-void-bg/80 pointer-events-none z-[1]"></div>

      <header class="relative z-10 flex justify-between items-center p-6 md:p-10 text-sm font-mono uppercase tracking-widest text-void-mute">
        <span class="text-void-fg/80">{dict.nav.studio}</span>
        <span class="hidden md:inline">{dict.nav.person}</span>
        <div class="flex items-center gap-4">
          <a href={dict.langSwitch.otherHref} class="hover:text-void-accent transition" aria-label="switch language">
            {dict.langSwitch.other}
          </a>
          <a href={`mailto:${dict.nav.contact}`} class="hover:text-void-accent transition hidden sm:inline">
            {dict.nav.contact}
          </a>
        </div>
      </header>

      <div class="relative z-10 flex flex-col gap-8 max-w-5xl px-6 md:px-10 py-8">
        <p class="font-mono text-xs uppercase tracking-[0.3em] text-void-accent/70">
          {dict.hero.eyebrow}
        </p>
        <h1 class="text-display text-[clamp(3.5rem,12vw,12rem)] text-void-fg text-glow">
          {dict.hero.title1}<br />
          <span class="text-void-accent">{dict.hero.title2}</span>
        </h1>
        <p class="max-w-2xl text-lg md:text-2xl text-void-fg/70 leading-relaxed font-light">
          {dict.hero.body.map((line, i) => (
            <>{line}{i < dict.hero.body.length - 1 && <br />}</>
          ))}
        </p>
      </div>

      <footer class="relative z-10 flex justify-between items-end p-6 md:p-10 font-mono text-xs uppercase tracking-widest text-void-mute">
        <a href="#projects" class="hover:text-void-accent transition flex items-center gap-2 group">
          <span class="group-hover:text-void-accent">{dict.hero.scroll}</span>
          <span class="inline-block w-5 h-5 rounded-full border border-void-accent/40 group-hover:border-void-accent flex items-center justify-center text-void-accent text-[10px]">↓</span>
        </a>
        <span class="hidden md:block">{dict.hero.location}</span>
      </footer>
    </section>

    <ProjectGrid dict={dict} />

    <footer class="relative bg-void-bg border-t border-cyan-900/30 py-10 px-6 md:px-16">
      <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between gap-4 font-mono text-xs uppercase tracking-widest text-void-mute">
        <span>{dict.footer.rights}</span>
        <div class="flex gap-6">
          <a href={`mailto:${dict.nav.contact}`} class="hover:text-void-accent transition">
            {dict.nav.contact}
          </a>
          <span class="hidden md:inline">{dict.footer.poweredBy}</span>
        </div>
      </div>
    </footer>
  </main>
</Layout>
