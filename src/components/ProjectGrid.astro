---
import type { PublicProject } from "../lib/registry";
import { loadRegistry } from "../lib/registry";
import type { Dict } from "../i18n/zh";
import ProjectCard from "./ProjectCard.astro";

interface Props {
  dict: Dict;
}
const { dict } = Astro.props;

const registry = await loadRegistry();
const projects = registry.projects
  .filter((p) => p.featured)
  .sort((a, b) => (a.showcase_rank ?? 999) - (b.showcase_rank ?? 999));

const featured = projects.slice(0, 2);
const rest = projects.slice(2);
---

<section id="projects" class="relative overflow-hidden px-5 py-24 md:px-8 md:py-32">
  <div class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_18%_8%,rgba(0,122,255,0.10),transparent_30rem),radial-gradient(circle_at_80%_18%,rgba(255,107,53,0.09),transparent_26rem),linear-gradient(180deg,#f7f8fa_0%,#ffffff_42%,#eef2f7_100%)]" />
  <div class="mx-auto max-w-7xl">
    <div class="mb-12 grid items-end gap-6 md:mb-16 md:grid-cols-[1fr_minmax(280px,0.42fr)]">
      <div>
        <p class="mb-4 w-fit rounded-full border border-white/80 bg-white/62 px-4 py-2 font-mono text-[11px] uppercase tracking-[0.26em] text-void-accent shadow-[0_14px_46px_rgba(0,122,255,0.09)] backdrop-blur-2xl">
          {dict.projects.eyebrow}
        </p>
        <h2 class="text-display text-5xl text-void-ink md:text-8xl">
          {dict.projects.title}
        </h2>
      </div>
      <p class="rounded-[1.75rem] border border-white/80 bg-white/60 p-5 text-sm font-medium leading-relaxed text-void-ink/66 shadow-[0_20px_70px_rgba(28,39,58,0.09)] backdrop-blur-2xl md:text-base">
        {dict.projects.subtitle}
      </p>
    </div>

    {projects.length === 0 ? (
      <p class="text-void-mute">{dict.projects.empty}</p>
    ) : (
      <div class="grid grid-cols-1 gap-5 auto-rows-[minmax(280px,auto)] md:grid-cols-3 md:gap-6 lg:grid-cols-4">
        {featured.map((p) => (
          <ProjectCard p={p} dict={dict} big />
        ))}
        {rest.map((p) => (
          <ProjectCard p={p} dict={dict} />
        ))}
      </div>
    )}
  </div>
</section>
