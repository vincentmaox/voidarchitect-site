---
import ProductDetailPage from "../../../components/ProductDetailPage.astro";
import { en } from "../../../i18n/en";
import { loadRegistry } from "../../../lib/registry";
import { isFeaturedProductSlug, productSlug } from "../../../lib/product-details";

export const prerender = false;

const { slug } = Astro.params;

if (!slug || !isFeaturedProductSlug(slug)) {
  return Astro.redirect("/en/", 302);
}

const registry = await loadRegistry();
const project = registry.projects.find((p) => productSlug(p) === slug && p.featured);

if (!project) {
  return Astro.redirect("/en/", 302);
}

const related = registry.projects
  .filter((p) => p.featured && productSlug(p) && productSlug(p) !== slug)
  .sort((a, b) => (a.showcase_rank ?? 999) - (b.showcase_rank ?? 999))
  .slice(0, 4);
---

<ProductDetailPage slug={slug} project={project} related={related} dict={en} locale="en" />
